{
  "name": "@owostack/core",
  "version": "0.1.0",
  "description": "Core SDK for Owostack - Paystack made delightful",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulmumin1/owostack.git",
    "directory": "packages/core"
  },
  "type": "module",
  "files": ["dist"],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest",
    "lint": "eslint src/"
  },
  "keywords": ["paystack", "billing", "subscriptions", "usage-based", "africa", "payments"],
  "dependencies": {
    "@owostack/types": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "publishConfig": {
    "access": "public"
  }
}
