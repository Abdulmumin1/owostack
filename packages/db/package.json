{
  "name": "@owostack/db",
  "version": "0.1.0",
  "description": "Database schema and utilities for Owostack",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "private": true,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "import": "./dist/schema/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/schema/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/schema/index.ts --format esm --dts --watch",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply owostack --local",
    "db:migrate:prod": "wrangler d1 migrations apply owostack --remote",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [
    "owostack",
    "database",
    "drizzle",
    "d1"
  ],
  "dependencies": {
    "drizzle-orm": "^0.41.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "drizzle-kit": "^0.30.4",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "wrangler": "^4.62.0"
  }
}
