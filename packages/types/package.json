{
  "name": "@owostack/types",
  "version": "0.2.0",
  "description": "Shared TypeScript types for Owostack",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Abdulmumin1/owostack",
    "directory": "packages/types"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch"
  },
  "devDependencies": {
    "tsup": "^8.3.6",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
