# API URLs per environment
# In development, both point to localhost. In production, each points to its own worker.
# Both workers share a DB_AUTH binding for auth, so sessions work on either.
VITE_API_URL_TEST=http://localhost:8787
VITE_API_URL_LIVE=http://localhost:8787
VITE_DOCS_URL=http://localhost:3000/docs
# Enabled providers are controlled by the API's ENABLED_PROVIDERS env var.
# The dashboard queries GET /api/dashboard/providers/enabled at runtime.
